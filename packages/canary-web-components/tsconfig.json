{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "lib": ["dom", "es2017"],
    "module": "esnext",
    "target": "es2017",
    "jsxFactory": "h",
    "allowJs": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true
  },
  "include": ["src", "./node.d.ts"],
  "exclude": [
    "node_modules",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
