{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "experimentalDecorators": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "allowSyntheticDefaultImports": true,
    "declarationDir": "./dist/types",
    "target": "ES2020",
    "noImplicitAny": true,
    "jsx": "react",
    "allowJs": true,
    "types": ["cypress", "node", "cypress-axe"],
    "skipLibCheck": true 
  },
  "include": [
    "lib",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "**/__tests__/**",
    "cypress/**",
    "src/component-tests/**/*",
    "node_modules"
  ],
  "compileOnSave": false,
  "buildOnSave": false
}